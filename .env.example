AFFILIATE_SCHWAB=https://www.schwab.com/
AFFILIATE_VANGUARD=https://www.vanguard.com/
AFFILIATE_ROBINHOOD=https://www.robinhood.com/
AFFILIATE_WEBULL=https://app.webull.com/
AFFILIATE_M1=https://www.m1finance.com/

# Robo-advisors
AFFILIATE_BETTERMENT=https://www.betterment.com/
AFFILIATE_WEALTHFRONT=https://www.wealthfront.com/

# Tax software
AFFILIATE_TURBOTAX=https://www.turbotax.intuit.com/
AFFILIATE_TAXACT=https://www.taxact.com/
AFFILIATE_FREETAXUSA=https://www.freetaxusa.com/

# Life insurance
AFFILIATE_BESTOW=https://www.bestow.com/
AFFILIATE_ETHOS=https://www.ethoslife.com/
AFFILIATE_HAVEN=https://www.havenlife.com/
AFFILIATE_LADDER=https://www.ladderlife.com/
AFFILIATE_POLICYGENIUS=https://www.policygenius.com/

# Credit cards
AFFILIATE_CHASE_SAPPHIRE_PREFERRED=https://www.creditcards.com/credit-cards/chase-sapphire-preferred/
AFFILIATE_AMEX_GOLD=https://www.americanexpress.com/
AFFILIATE_CITI_DOUBLE_CASH=https://www.citi.com/credit-cards/credit-card-details/citi-double-cash-card.html
AFFILIATE_CAPITAL_ONE_VENTURE=https://www.capitalone.com/credit-cards/venture/
AFFILIATE_CHASE_SAPPHIRE_RESERVE=https://www.chase.com/personal/credit-cards/sapphire/reserve
AFFILIATE_CAPITAL_ONE_SAVOR=https://www.capitalone.com/credit-cards/savor-cash/

# HSA
AFFILIATE_LIVELY=https://www.livelyhq.com/
AFFILIATE_FIDELITY_HSA=https://www.fidelity.com/go/hsa
AFFILIATE_HEALTHEQUITY=https://www.healthequity.com/

# Budgeting
AFFILIATE_YNAB=https://www.youneedabudget.com/

# Multi-currency
AFFILIATE_WISE=https://wise.com/

# Secured credit cards (starter)
AFFILIATE_CAPITAL_ONE=https://www.capitalone.com/
AFFILIATE_DISCOVER_IT=https://www.discover.com/

# Credit monitoring
AFFILIATE_CREDIT_KARMA=https://www.creditkarma.com/

# Newsletter (beehiiv) — server-only; never exposed to the client.
# API key: beehiiv dashboard → Settings → API. Publication ID starts with "pub_".
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# Weekly newsletter cron — Anthropic Haiku writes the lead-story intro.
# Get a key at console.anthropic.com → API Keys.
ANTHROPIC_API_KEY=

# Shared secret for Vercel Cron → /api/cron/* routes. Generate any opaque
# string (e.g. `openssl rand -hex 32`). Vercel Cron sends it as
# `Authorization: Bearer ${CRON_SECRET}`.
CRON_SECRET=

# Resend — used to email the weekly newsletter draft. Optional: if unset,
# the cron just logs the draft and returns it as JSON.
# Get a key at resend.com → API Keys. From-address must be on a verified
# domain (set up finbrief.space in Resend → Domains; DNS records via
# Hostinger). To-address is where the draft lands each Monday.
RESEND_API_KEY=
NEWSLETTER_FROM=Finbrief <newsletter@finbrief.space>
NEWSLETTER_DRAFT_TO=admin@finbrief.space
