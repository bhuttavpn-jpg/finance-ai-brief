# Public site URL — used for sitemap, OG, canonical
NEXT_PUBLIC_SITE_URL=https://finbrief.space

# Site name shown in header & metadata
NEXT_PUBLIC_SITE_NAME=Finbrief

# Optional: analytics
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Affiliate URLs — PLACEHOLDER: Using institution homepages for now.
# Replace these with real tracked affiliate links from:
# - Bankrate CC network, Impact, Fintel Connect for high-volume partners
# - CJ, FlexOffers, or direct brokerage/insurance networks for others
# Server-side only (don't leak the real URL to the client).

# HYSA & Banking
AFFILIATE_MARCUS=https://www.marcus.com/
AFFILIATE_ALLY=https://www.ally.com/
AFFILIATE_SOFI_MONEY=https://www.sofi.com/money-market-account/
AFFILIATE_SOFI_INVEST=https://www.sofi.com/invest/
AFFILIATE_CIT=https://www.citbank.com/

# Brokerages
